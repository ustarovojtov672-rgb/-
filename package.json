{
  "name": "calorie-bot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "jazz:sync": "jazz-run sync --host 127.0.0.1 --port 4200 --db ./.jazz-sync/storage.db",
    "auth:setup": "node scripts/create-auth-worker.mjs",
    "build:web": "next build",
    "build:mobile": "set NEXT_OUTPUT=export&& next build",
    "cap:sync": "npm run build:mobile && cap sync",
    "cap:copy": "npm run build:mobile && cap copy",
    "pi": "pi",
    "pi:install-codex-search": "pi install npm:pi-codex-search -l --approve",
    "nutrition-agent:login": "powershell -NoProfile -ExecutionPolicy Bypass -File \"./Аi агент питания/login-openai-codex.ps1\"",
    "nutrition-agent:sync-codex-auth": "powershell -NoProfile -ExecutionPolicy Bypass -File \"./Аi агент питания/sync-codex-auth.ps1\"",
    "nutrition-agent:run": "powershell -NoProfile -ExecutionPolicy Bypass -File \"./Аi агент питания/run-nutrition-agent.ps1\"",
    "build": "next build",
    "start": "next start",
    "start:mobile": "serve out",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@capacitor/core": "^8.4.0",
    "better-auth": "^1.6.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cojson": "^0.20.18",
    "cojson-transport-ws": "^0.20.18",
    "jazz-tools": "^0.20.18",
    "just-bash": "^3.0.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "openai": "^6.42.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@earendil-works/pi-coding-agent": "^0.79.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jazz-run": "^0.20.18",
    "serve": "^14.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "ws": "^8.21.0"
  }
}
